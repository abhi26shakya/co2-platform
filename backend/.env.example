# Backend environment - copy to .env
CO2_DATABASE_URL=postgresql+asyncpg://co2:co2password@localhost:5432/co2_platform
CO2_ML_SERVICE_URL=http://localhost:8001
CO2_INFERENCE_BACKEND=http
CO2_STORAGE_BACKEND=local
CO2_STORAGE_LOCAL_PATH=./storage
CO2_JWT_SECRET_KEY=change-me-in-production
CO2_CORS_ORIGINS=["http://localhost:3000"]
CO2_RATE_LIMIT_ENABLED=1
CO2_AUTH_RATE_LIMIT=30/minute
CO2_RATE_LIMIT_STORAGE=memory://   # redis://redis:6379/1 in production
